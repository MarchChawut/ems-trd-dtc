# ============================================
# EMS Admin — Environment Variables Template
# ============================================
# 1. copy ไฟล์นี้: cp .env.example .env
# 2. แทนค่าทุกตัวด้วยค่าจริง (อย่า commit .env เข้า git)
# 3. สร้าง secret ด้วย:  openssl rand -base64 32
# ============================================

# --------------------------------------------
# Database (MariaDB)
# --------------------------------------------
# ใช้ strong password >= 24 ตัวอักษร — อย่าใช้ค่าตัวอย่างใน production
DB_ROOT_PASSWORD=CHANGE_ME_strong_root_password_min_24_chars
DB_NAME=ems_db
DB_USER=ems_user
DB_PASSWORD=CHANGE_ME_strong_user_password_min_24_chars
DB_PORT=3306
# bind interface: 127.0.0.1 = localhost only (production), 0.0.0.0 = ทุก interface (dev เท่านั้น)
DB_BIND_HOST=127.0.0.1

# Connection string สำหรับ Prisma — ประกอบจากตัวแปรด้านบน
# host: ใช้ "mariadb" ถ้า app รันใน docker-compose เดียวกัน, หรือ "localhost" ถ้ารัน app นอก docker
DATABASE_URL="mysql://ems_user:CHANGE_ME_strong_user_password_min_24_chars@localhost:3306/ems_db"

# --------------------------------------------
# Session / Auth Secrets
# --------------------------------------------
# สร้างใหม่ทั้งสอง: openssl rand -base64 32
# ❗ ห้ามนำ secret จาก dev มาใช้ production
NEXTAUTH_SECRET=CHANGE_ME_random_32_byte_base64_secret
NEXTAUTH_URL=http://localhost:3000

# --------------------------------------------
# phpMyAdmin (เฉพาะ admin profile — ปิดบน production)
# --------------------------------------------
PMA_PORT=8080

# --------------------------------------------
# Logging
# --------------------------------------------
LOG_LEVEL=info
# LOG_SERVICE=console     # 'console' | 'sentry' | 'loggly'
# LOG_SERVICE_URL=
# LOG_SERVICE_KEY=

# --------------------------------------------
# V.2.0 PII Vault (ยังไม่เปิดใช้งานใน V.1.x)
# --------------------------------------------
# VAULT_DATABASE_URL="mysql://vault_user:CHANGE_ME@vault-mariadb:3306/ems_vault"
# VAULT_KEK_BASE64=             # base64-encoded 32-byte master key
# VAULT_SEARCH_PEPPER_BASE64=   # base64-encoded >=16-byte pepper
# VAULT_DUAL_WRITE=false
# VAULT_READ_PERCENT=0
