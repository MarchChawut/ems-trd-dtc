// ============================================================
// EMS V.2.0 — Main DB Schema (PII REMOVED)
// ============================================================
//
// This is the END-STATE schema after Stage E (Contract) of the migration.
// During earlier stages, PII fields remain (nullable) until they are dropped.
//
// Differences from V.1.0:
//   - User: removed name, prefix, phone, birthday, address, email, profileImage
//   - User: added employeeCode (token), groupId, runningNumber
//   - User: username + password are nullable (EMPLOYEE has none)
//   - Role enum simplified: SUPER_ADMIN, ADMIN, EMPLOYEE only
//   - New: EmployeeGroup table

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// ============================================================
// Model: EmployeeGroup  ⭐ NEW
// ============================================================
// Managed by SUPER_ADMIN. Codes appear in employeeCode as prefix:
//   "TRD1-001234", "TRD2-001234", "DEV-001234"
model EmployeeGroup {
  id          Int      @id @default(autoincrement())
  code        String   @unique @db.VarChar(10)  // "TRD1", "TRD2", "DEV"
  name        String   @db.VarChar(100)         // "ทีม TRD ชุดที่ 1"
  description String?  @db.VarChar(255)
  isActive    Boolean  @default(true)
  order       Int      @default(0)

  users       User[]

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([isActive, order])
  @@map("employee_groups")
}

// ============================================================
// Model: User — PII fields removed (now in Vault DB)
// ============================================================
model User {
  id             Int      @id @default(autoincrement())

  // ⭐ Token: stable reference across Main DB and Vault DB
  employeeCode   String   @unique @db.VarChar(20)  // "TRD1-001234"
  groupId        Int
  runningNumber  Int

  // Login credentials — nullable; EMPLOYEE has both null
  username       String?  @unique @db.VarChar(100)
  password       String?  @db.VarChar(255)  // bcrypt hash

  role           Role     @default(EMPLOYEE)

  // Operational metadata (NOT PII)
  department     String?  @db.VarChar(100)
  division       String?  @db.VarChar(200)
  position       String?  @db.VarChar(100)
  positionSecond String?  @db.VarChar(100)
  positionLevel  Int?
  avatar         String?  @db.VarChar(10)   // ตัวย่อ "ก" — derived, not PII
  isActive       Boolean  @default(true)

  // ❌ REMOVED in V.2.0 (now lives in Vault DB):
  //    name, prefix, phone, birthday, address, email, profileImage

  group          EmployeeGroup  @relation(fields: [groupId], references: [id])
  tasks          Task[]
  leaves         Leave[]
  sessions       Session[]
  loginAttempts  LoginAttempt[]

  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@unique([groupId, runningNumber])
  @@index([role, isActive])
  @@index([groupId])
  @@map("users")
}

// ============================================================
// Session — unchanged from V.1.0
// ============================================================
model Session {
  id        Int      @id @default(autoincrement())
  userId    Int
  token     String   @unique @db.VarChar(500)
  expiresAt DateTime
  ipAddress String?  @db.VarChar(45)
  userAgent String?  @db.Text
  isValid   Boolean  @default(true)

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@map("sessions")
}

// ============================================================
// LoginAttempt — unchanged from V.1.0
// ============================================================
model LoginAttempt {
  id        Int      @id @default(autoincrement())
  userId    Int?
  username  String   @db.VarChar(100)
  ipAddress String   @db.VarChar(45)
  success   Boolean
  reason    String?  @db.VarChar(255)

  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  createdAt DateTime @default(now())

  @@index([ipAddress, createdAt])
  @@index([username, createdAt])
  @@map("login_attempts")
}

// ============================================================
// KanbanColumn, Task — unchanged from V.1.0
// ============================================================
model KanbanColumn {
  id        Int      @id @default(autoincrement())
  name      String   @db.VarChar(50)
  color     String   @default("slate") @db.VarChar(20)
  order     Int      @default(0)
  isDefault Boolean  @default(false)

  tasks     Task[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([order])
  @@map("kanban_columns")
}

model Task {
  id          Int        @id @default(autoincrement())
  title       String     @db.VarChar(255)
  description String?    @db.Text
  columnId    Int        @default(1)
  priority    Priority   @default(MEDIUM)
  assigneeId  Int?
  reminderAt  DateTime?
  archivedAt  DateTime?

  column     KanbanColumn @relation(fields: [columnId], references: [id], onDelete: Restrict)
  assignee   User?        @relation(fields: [assigneeId], references: [id], onDelete: SetNull)

  createdAt  DateTime     @default(now())
  updatedAt  DateTime     @updatedAt

  @@index([columnId])
  @@index([assigneeId])
  @@map("tasks")
}

// ============================================================
// Leave, LeaveRule — unchanged from V.1.0
// (reason field — note: not classified as PII for our purposes,
//  treat as operational data. If sensitive medical reasons need
//  encryption, add to Vault Identity in a follow-up RFC.)
// ============================================================
model Leave {
  id             Int         @id @default(autoincrement())
  userId         Int
  type           LeaveType
  startDate      DateTime    @db.Date
  endDate        DateTime    @db.Date
  reason         String      @db.Text
  status         LeaveStatus @default(PENDING)
  approvedBy     Int?
  approvedAt     DateTime?

  isHalfDay      Boolean     @default(false)
  hours          Float?
  totalDays      Float       @default(0)
  contactAddress String?     @db.Text

  user           User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  @@index([userId])
  @@index([status])
  @@index([startDate, endDate])
  @@map("leaves")
}

model LeaveRule {
  id                 Int      @id @default(autoincrement())
  name               String   @db.VarChar(100)
  startTime          String   @db.VarChar(5)
  endTime            String   @db.VarChar(5)
  fullDayHours       Float    @default(8)
  halfDayHours       Float    @default(4)
  maxConsecutiveDays Int      @default(30)
  isActive           Boolean  @default(true)

  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  @@map("leave_rules")
}

// Department, Position, PositionSecond, Holiday — unchanged from V.1.0
// (omitted here for brevity — keep V.1.0 definitions as-is)

// ============================================================
// Enums
// ============================================================

enum Role {
  SUPER_ADMIN  // chawut.sa, spore — login + reveal PII (step-up auth)
  ADMIN        // slyth, spad — login, manage data, NO reveal
  EMPLOYEE     // data record only, NO login (username=null, password=null)
}

enum TaskStatus { TODO IN_PROGRESS DONE }
enum Priority   { LOW MEDIUM HIGH URGENT }

enum LeaveType {
  SICK
  PERSONAL
  VACATION
  MATERNITY
  ORDINATION
  EARLY_LEAVE
  OTHER
}

enum LeaveStatus { PENDING APPROVED REJECTED }
