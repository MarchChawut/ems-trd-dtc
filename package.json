{
  "name": "ems-admin",
  "version": "1.0.0",
  "description": "Employee Management System - Next.js Fullstack with MariaDB",
  "private": true,
  "scripts": {
    "postinstall": "prisma generate",
    "dev": "next dev",
    "build": "next build",
    "start": "next start --hostname 0.0.0.0 --port 3000",
    "lint": "next lint",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:studio": "prisma studio",
    "db:seed": "tsx prisma/seed.ts",
    "db:import-assets": "tsx scripts/import-assets.ts",
    "db:migrate-uploads": "tsx scripts/migrate-uploads-to-db.ts",
    "db:fix-leave-years": "tsx scripts/fix-leave-buddhist-years.ts",
    "db:fix-document-years": "tsx scripts/fix-document-buddhist-years.ts",
    "db:fix-html-entities": "tsx scripts/fix-html-entity-escaped-text.ts",
    "db:backup": "tsx scripts/backup.ts",
    "db:backup:list": "tsx scripts/backup.ts list",
    "db:restore": "tsx scripts/backup.ts restore",
    "worker:reminders": "tsx worker/reminder-worker.ts",
    "worker:cron-healthcheck": "tsx worker/cron-healthcheck.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "test:db:up": "docker compose -f docker-compose.test.yml up -d",
    "test:db:down": "docker compose -f docker-compose.test.yml down -v",
    "test:all": "pnpm test:db:up && pnpm test && pnpm test:e2e && pnpm test:db:down"
  },
  "dependencies": {
    "@prisma/client": "^5.7.0",
    "@radix-ui/react-avatar": "^1.0.4",
    "@radix-ui/react-dialog": "^1.0.5",
    "@radix-ui/react-dropdown-menu": "^2.0.6",
    "@radix-ui/react-label": "^2.0.2",
    "@radix-ui/react-select": "^2.0.0",
    "@radix-ui/react-separator": "^1.0.3",
    "@radix-ui/react-slot": "^1.0.2",
    "@radix-ui/react-toast": "^1.1.5",
    "@radix-ui/react-tooltip": "^1.0.7",
    "@react-pdf/renderer": "^4.3.2",
    "@simplewebauthn/browser": "^13.3.0",
    "@simplewebauthn/server": "^13.3.2",
    "bcryptjs": "^2.4.3",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.0.0",
    "dompurify": "^3.0.6",
    "exceljs": "^4.4.0",
    "express-rate-limit": "^7.1.5",
    "file-type": "^22.0.1",
    "helmet": "^7.1.0",
    "isomorphic-dompurify": "^2.0.0",
    "jsonwebtoken": "^9.0.2",
    "lucide-react": "^0.563.0",
    "next": "^16.0.0",
    "otplib": "^13.4.1",
    "prisma": "^5.7.0",
    "qrcode": "^1.5.4",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "recharts": "^3.7.0",
    "tailwind-merge": "^2.2.0",
    "tailwindcss-animate": "^1.0.7",
    "tsx": "^4.7.0",
    "xlsx": "^0.18.5",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/bcryptjs": "^2.4.6",
    "@types/dompurify": "^3.0.5",
    "@types/jsonwebtoken": "^9.0.5",
    "@types/node": "^22.19.11",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^6.0.3",
    "autoprefixer": "^10.4.16",
    "jsdom": "^29.1.1",
    "postcss": "^8.4.32",
    "tailwindcss": "^3.4.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3",
    "vite-tsconfig-paths": "^6.1.1",
    "vitest": "^4.1.10"
  },
  "prisma": {
    "seed": "node dist-seed/prisma/seed.js"
  }
}
