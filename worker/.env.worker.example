# ==================================================
# worker/.env.worker — env สำหรับ cron trigger (least privilege)
# ==================================================
# คัดลอกไฟล์นี้เป็น worker/.env.worker แล้ว chmod 600
# ใช้โดย scripts/cron-reminders.sh และ worker/reminder-worker.ts
# ไม่ต้องมี DATABASE_URL / LINE token — แค่ค่าด้านล่างพอ

# (จำเป็น) ต้องตรงกับ CRON_SECRET ใน .env ของแอป
CRON_SECRET="change-me"

# (ไม่บังคับ) URL ของ endpoint — default http://127.0.0.1:3000/api/cron/reminders
# REMINDER_TARGET_URL="http://127.0.0.1:3000/api/cron/reminders"

# (ไม่บังคับ) Healthchecks.io ping URL (dead man's switch)
# HEALTHCHECK_PING_URL="https://hc-ping.com/xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx"

# (ไม่บังคับ) ไฟล์ log — default <app>/logs/worker.log
# CRON_LOG_FILE="/volume1/web/ems-admin/logs/worker.log"
